AMBIENTE=desenvolvimento

# "anthropic" usa a API real; "fake" roda sem rede (útil em testes e demonstrações).
PROVEDOR_LLM=anthropic
# Obrigatória quando PROVEDOR_LLM=anthropic. Nunca versione o valor real.
ANTHROPIC_API_KEY=
MODELO_LLM=claude-opus-4-8

# "local" baixa o modelo de embeddings na primeira ingestao (sem chave, sem rede
# depois disso); "hashing" e um saco de palavras sem download.
EMBEDDER=local
MODELO_EMBEDDING=sentence-transformers/all-MiniLM-L6-v2

DATABASE_URL=postgresql+asyncpg://chatbot:chatbot@localhost:5437/chatbot
REDIS_URL=redis://localhost:6383/0

ORIGENS_PERMITIDAS=["http://localhost:8000"]

# Rate limit (janela deslizante de 60s) e teto de custo por conversa.
MENSAGENS_POR_MINUTO_POR_IP=20
MENSAGENS_POR_MINUTO_POR_CONVERSA=10
TETO_DE_TOKENS_POR_CONVERSA=50000
VALIDADE_DO_ORCAMENTO_SEGUNDOS=86400
